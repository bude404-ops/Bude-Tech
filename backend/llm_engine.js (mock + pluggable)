export async function runLLM(swarm, market, personality) {
  const score =
    swarm.reduce((s, a) => s + (a.bias === "LONG" ? 1 : -1) * a.confidence, 0);

  return {
    bias: score > 0 ? "LONG" : "SHORT",
    confidence: Math.min(1, Math.abs(score) / 2),
    reasoning: "Aggregated swarm consensus + market personality adjustment"
  };
}
