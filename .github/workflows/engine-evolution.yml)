name: Engine Evolution Loop
on:
  schedule:
    - cron: '*/30 * * * *' # Runs every 30 minutes
  workflow_dispatch: # Allows manual trigger

jobs:
  evolve:
    runs-on: ubuntu-latest
    permissions:
      contents: write # Essential: Allows the agent to push code back to the repo
    steps:
      - uses: actions/checkout@v4
      - name: Run Autonomy Agent
        run: |
          python3 system/controller.py --mode=evolution
      - name: Commit & Push Changes
        run: |
          git config user.name "Bude-Tech-Agent"
          git config user.email "agent@bude.tech"
          git add .
          git diff --quiet && git diff --staged --quiet || (git commit -m "Auto-evolve: System expansion" && git push)
